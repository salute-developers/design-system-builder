FROM node:20-alpine

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_DS_REGISTRY_API
ENV VITE_DS_REGISTRY_API=$VITE_DS_REGISTRY_API
ARG VITE_DS_GENERATOR_API
ENV VITE_DS_GENERATOR_API=$VITE_DS_GENERATOR_API
ARG VITE_DS_DOCUMENTATION_GENERATOR_API
ENV VITE_DS_DOCUMENTATION_GENERATOR_API=$VITE_DS_DOCUMENTATION_GENERATOR_API
ARG VITE_NPM_REGISTRY
ENV VITE_NPM_REGISTRY=$VITE_NPM_REGISTRY
ENV NODE_ENV=production
RUN npm run build
EXPOSE 4173
CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "4173"]
